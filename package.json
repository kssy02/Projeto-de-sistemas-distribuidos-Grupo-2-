{
  "name": "projeto-raiz",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "front",
    "back"
  ],
 "scripts": {
    "back": "npm run dev --workspace=back",
    "front": "npm run dev --workspace=front",
    "liberar-terminal": "powershell -Command \"Set-ExecutionPolicy -ExecutionPolicy RemoteSigned -Scope CurrentUser\"",
    "dev": "concurrently \"npm run back\" \"npm run front\""
  },
  "dependencies": {
    "@tursodatabase/vercel-experimental": "^0.1.0"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}